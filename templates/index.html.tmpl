<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{.RepoName}}</title>
    <link rel="icon" type="image/png" href="{{.RepoURL}}CydiaIcon.png" />
    <link rel="apple-touch-icon" href="{{.RepoURL}}CydiaIcon.png" />
    <style>
      :root {
        --bg: #f4f3ef;
        --panel: #ffffff;
        --ink: #1e2936;
        --muted: #596879;
        --line: #dae2eb;
        --line-strong: #c2cfdd;
        --hero-top: #fffef8;
        --hero-bottom: #f4f9ff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Avenir Next", "Nunito Sans", "Segoe UI", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(1200px 520px at 85% -12%, #d9efff 0%, rgba(217, 239, 255, 0) 62%),
          radial-gradient(920px 520px at -16% 110%, #fce9d5 0%, rgba(252, 233, 213, 0) 65%),
          linear-gradient(180deg, #fcfbf8 0%, #f4f3ef 100%),
          var(--bg);
        min-height: 100vh;
      }
      .wrap {
        width: min(980px, 92vw);
        margin: 0 auto;
        padding: 2.8rem 0 3.8rem;
      }
      .hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient(138deg, var(--hero-top) 0%, var(--hero-bottom) 100%);
        border: 1px solid var(--line);
        border-radius: 22px;
        padding: 1.8rem;
        box-shadow: 0 16px 40px rgba(31, 43, 56, 0.09);
        animation: rise 0.65s ease both;
      }
      .hero::before {
        content: "";
        position: absolute;
        right: -120px;
        top: -120px;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(125, 176, 228, 0.22) 0%, rgba(125, 176, 228, 0) 68%);
        pointer-events: none;
      }
      .title {
        margin: 0;
        font-size: clamp(1.8rem, 2.8vw, 2.8rem);
        letter-spacing: 0.015em;
      }
      .subtitle {
        margin-top: 0.7rem;
        color: var(--muted);
        line-height: 1.45;
      }
      .hint {
        margin: 0.85rem 0 0;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .grid {
        margin-top: 1.1rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 0.8rem;
      }
      .menu {
        margin: 0;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.82);
        overflow: hidden;
      }
      .menu > summary {
        position: relative;
        display: block;
        cursor: pointer;
        padding: 0.82rem 2.1rem 0.82rem 0.95rem;
        font-weight: 700;
        text-align: left;
        line-height: 1.3;
        list-style: none;
        transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease;
        background: var(--menu-bg);
        color: var(--menu-fg);
      }
      .menu > summary::after {
        content: "▾";
        position: absolute;
        right: 0.9rem;
        top: 50%;
        margin-top: -0.5em;
        display: block;
        font-size: 0.92rem;
        line-height: 1;
        transition: transform 140ms ease;
      }
      .menu > summary::-webkit-details-marker { display: none; }
      .menu > summary:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 18px rgba(31, 43, 56, 0.16);
      }
      .menu[open] > summary::after {
        transform: rotate(180deg);
      }
      .menu-list {
        margin: 0;
        display: grid;
        gap: 0.4rem;
        background: rgba(255, 255, 255, 0.95);
        border-top: 1px solid var(--line);
        padding: 0.45rem;
      }
      .menu-link {
        display: block;
        text-decoration: none;
        border-radius: 9px;
        padding: 0.56rem 0.68rem;
        font-weight: 600;
        color: var(--ink);
        background: #fff;
        border: 1px solid var(--line);
        transition: background 130ms ease, border-color 130ms ease, transform 130ms ease;
      }
      .menu-link:hover {
        background: #f8fbff;
        border-color: var(--line-strong);
        transform: translateY(-1px);
      }
      .menu-cydia { --menu-bg: #111827; --menu-fg: #fff; }
      .menu-zebra { --menu-bg: #ffc857; --menu-fg: #2d2424; }
      .menu-sileo { --menu-bg: #2f6690; --menu-fg: #fff; }
      .panel {
        margin-top: 1rem;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 15px;
        padding: 1rem;
        animation: rise 0.9s ease both;
      }
      .label {
        margin: 0 0 0.4rem;
        font-size: 0.92rem;
        color: var(--muted);
      }
      .code {
        margin: 0;
        border-radius: 10px;
        background: #1f2730;
        color: #f5f8fb;
        font-family: "JetBrains Mono", "Cascadia Code", monospace;
        padding: 0.7rem;
        overflow-x: auto;
      }
      .footer {
        margin-top: 1.1rem;
        color: var(--muted);
        font-size: 0.92rem;
      }
      @keyframes rise {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @media (max-width: 700px) {
        .wrap {
          width: 94vw;
          padding: 2rem 0 2.8rem;
        }
        .hero {
          padding: 1.25rem;
          border-radius: 18px;
        }
        .panel {
          padding: 0.85rem;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="hero">
        <h1 class="title">{{.RepoName}}</h1>
        <p class="subtitle">
          Debian-style APT repository for iOS packages. This page works as both a human-friendly gateway
          and a direct source endpoint for package managers.
        </p>
        <p class="hint">Tap sections to expand source options.</p>
        <div class="grid">
          <details class="menu menu-cydia" id="menu-cydia"><summary>Add to Cydia</summary><div class="menu-list">
            {{range .Suites}}<a class="menu-link" href="{{.CydiaURL}}">{{.Label}}</a>
            {{end}}</div></details>
          <details class="menu menu-zebra" id="menu-zebra"><summary>Add to Zebra</summary><div class="menu-list">
            {{range .Suites}}<a class="menu-link" href="{{.ZebraURL}}">{{.Label}}</a>
            {{end}}</div></details>
          <details class="menu menu-sileo" id="menu-sileo"><summary>Add to Sileo</summary><div class="menu-list">
            {{range .Suites}}<a class="menu-link" href="{{.SileoURL}}">{{.Label}}</a>
            {{end}}</div></details>
        </div>
      </section>

      <section class="panel">
        <p class="label">Source lines</p>
        {{range .Suites}}<p class="code">deb {{.URL}} ./</p>
        {{end}}
      </section>

      <section class="panel">
        <p class="label">Useful files</p>
        {{range .Suites}}<p class="code">{{.URL}}Release</p>
        {{end}}
        {{if $.Signed}}{{range .Suites}}<p class="code">{{.URL}}InRelease</p>
        {{end}}{{end}}
        {{range .Suites}}<p class="code">{{.URL}}Packages</p>
        {{end}}
        {{if .HasPublicKey}}<p class="code">{{.RepoURL}}repo-public.key</p>{{end}}
      </section>

      <p class="footer">Generated: {{.GeneratedAt}}</p>
    </main>
  </body>
</html>
